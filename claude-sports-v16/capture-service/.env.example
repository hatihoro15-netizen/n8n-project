# 캡처 서비스 환경변수
# .env.example → .env 로 복사 후 실제 값으로 변경

# 서비스 포트
CAPTURE_PORT=3100

# 캡처 대상 사이트 (라이브365 / scoredata.org)
CAPTURE_BASE_URL=https://scoredata.org

# Puppeteer 크롬 경로 (Docker에서는 /usr/bin/chromium)
CHROMIUM_PATH=/usr/bin/chromium

# MinIO 설정
MINIO_ENDPOINT=172.17.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET=captures
MINIO_PUBLIC_HOST=172.17.0.1
