    {
      "parameters": {
        "jsCode": "// Creatomate 렌더 폴링\nconst renderId = $input.first().json.id || $input.first().json[0]?.id;\nconst apiKey = $credentials?.httpHeaderAuth?.value || '';\n\nlet status = 'planned';\nlet url = null;\nlet attempts = 0;\nconst maxAttempts = 60;\n\nwhile (!['succeeded', 'failed'].includes(status) && attempts < maxAttempts) {\n  await new Promise(r => setTimeout(r, 5000));\n  const resp = await fetch(`https://api.creatomate.com/v1/renders/${renderId}`, {\n    headers: { 'Authorization': `Bearer ${apiKey}` }\n  });\n  const data = await resp.json();\n  status = data.status;\n  url = data.url;\n  attempts++;\n}\n\nif (status !== 'succeeded' || !url) {\n  throw new Error(`영상 렌더링 실패: ${status}`);\n}\n\nconst prev = $('영상 렌더링 (Creatomate)').first().json;\nreturn [{\n  json: {\n    ...prev,\n    rendered_video_url: url,\n    render_id: renderId\n  }\n}];"
      },
