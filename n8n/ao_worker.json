    {
      "parameters": {
        "jsCode": "// Replicate 폴링 — 완료될 때까지 대기\nconst predictionId = $input.first().json.id;\nconst apiKey = $credentials?.httpHeaderAuth?.value || '';\n\nlet status = 'starting';\nlet output = null;\nlet attempts = 0;\nconst maxAttempts = 30;\n\nwhile (!['succeeded', 'failed', 'canceled'].includes(status) && attempts < maxAttempts) {\n  await new Promise(r => setTimeout(r, 3000));\n  const resp = await fetch(`https://api.replicate.com/v1/predictions/${predictionId}`, {\n    headers: { 'Authorization': `Bearer ${apiKey}` }\n  });\n  const data = await resp.json();\n  status = data.status;\n  output = data.output;\n  attempts++;\n}\n\nif (status !== 'succeeded' || !output) {\n  throw new Error(`이미지 생성 실패: ${status}`);\n}\n\nconst prev = $('이미지 생성 필요 여부').first().json;\nreturn [{\n  json: {\n    ...prev,\n    generated_images: Array.isArray(output) ? output : [output]\n  }\n}];"
      },
