      {
        "parameters": {
          "jsCode": "// ✅ AO 프롬프트 조립기 — P1 원문 100% 보존\nconst job = $input.first().json;\n\n// P1 원문은 절대 변경 금지\nconst p1 = job.prompt_p1;\nif (!p1) throw new Error('P1 원문 없음 — 작업 중단');\n\n// 이미지 슬롯 파싱\nlet imageSlots = {};\ntry {\n  imageSlots = typeof job.image_slots === 'string'\n    ? JSON.parse(job.image_slots)\n    : (job.image_slots || {});\n} catch(e) {\n  imageSlots = {};\n}\n\n// 슬롯 값 준비 (없으면 빈 문자열)\nconst slotValues = {\n  TOPIC: job.topic || '',\n  KEYWORDS: job.keywords || '',\n  CATEGORY: job.category || '',\n  IMG_1: imageSlots.IMG_1 || '',\n  IMG_2: imageSlots.IMG_2 || '',\n  IMG_3: imageSlots.IMG_3 || '',\n  IMG_4: imageSlots.IMG_4 || '',\n  REF_VIDEO: job.ref_video || '',\n  LANG: job.prompt_lang_detected || 'ko',\n  ASPECT_RATIO: '9:16'\n};\n\n// 누락 슬롯 로그 수집\nconst missedSlots = Object.entries(slotValues)\n  .filter(([k, v]) => !v)\n  .map(([k]) => k);\n\n// 최종 프롬프트: P1 그대로 + 슬롯 주입\nconst finalPrompt = p1\n  .replace(/\\{TOPIC\\}/g, slotValues.TOPIC)\n  .replace(/\\{KEYWORDS\\}/g, slotValues.KEYWORDS)\n  .replace(/\\{CATEGORY\\}/g, slotValues.CATEGORY)\n  .replace(/\\{IMG_1\\}/g, slotValues.IMG_1)\n  .replace(/\\{IMG_2\\}/g, slotValues.IMG_2)\n  .replace(/\\{IMG_3\\}/g, slotValues.IMG_3)\n  .replace(/\\{IMG_4\\}/g, slotValues.IMG_4)\n  .replace(/\\{REF_VIDEO\\}/g, slotValues.REF_VIDEO)\n  .replace(/\\{LANG\\}/g, slotValues.LANG)\n  .replace(/\\{ASPECT_RATIO\\}/g, slotValues.ASPECT_RATIO);\n\nreturn [{\n  json: {\n    ...job,\n    prompt_to_engine: finalPrompt,\n    prompt_p1_preserved: p1,  // 원문 보존 확인용\n    missed_slots: missedSlots,\n    assembled_at: new Date().toISOString()\n  }\n}];"
        },
