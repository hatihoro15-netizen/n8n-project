    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  for (let i = 1; i <= 5; i++) {\n    const key = `caption${i}`;\n    if (item.json[key]) {\n      // 먼저 \\n 텍스트를 실제 줄바꿈으로 변환\n      item.json[key] = item.json[key].replace(/\\\\n/g, '\\n');\n      // 그 다음 실제 줄바꿈을 다시 \\n 텍스트로 (JSON용)\n      item.json[key] = item.json[key].replace(/\\n/g, '\\\\n');\n    }\n  }\n}\nreturn $input.all();"
      },
