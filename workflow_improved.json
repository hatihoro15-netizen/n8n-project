      "parameters": {
        "jsCode": "const text = $input.first().json.content.parts[0].text;\nconst data = JSON.parse(text);\n\nconst items = [];\nfor (let i = 1; i <= 5; i++) {\n  items.push({\n    json: {\n      text: data[`narration${i}`],\n      index: i\n    }\n  });\n}\n\nreturn items;"
      },
