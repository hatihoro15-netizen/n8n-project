    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst videoDuration = 5;\nconst bitrate = 128000;\nlet totalDuration = 0;\n\nfor (let i = 1; i <= 5; i++) {\n  const fileSize = item[`narration${i}Size`];\n  const duration = Math.round((fileSize * 8 / bitrate) * 100) / 100;\n  if (duration > videoDuration) {\n    item[`duration${i}`] = duration;\n    item[`speed${i}`] = Math.round((videoDuration / duration) * 100) + \"%\";\n  } else {\n    item[`duration${i}`] = duration;\n    item[`speed${i}`] = \"100%\";\n  }\n  totalDuration += item[`duration${i}`];\n}\n\nitem['videoT24Start'] = totalDuration;\nitem['totalDuration'] = totalDuration + 8;\n\nreturn [{ json: item }];"
      },
